# Servicio completo con voz específica
curl -X POST http://localhost:5000/generate_complete \
  -H "Content-Type: application/json" \
  -d '{"text": "Hola mundo", "voice": "dora"}' \
  --output audio_dora.mp3

# Ver voces disponibles
curl http://localhost:5000/voices

# Documentación
curl http://localhost:5000/


